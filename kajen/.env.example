# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit real credentials.

# Supabase (find in: supabase.com → project → settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only — never expose to browser

# QuickPay (find in: manage.quickpay.net → settings → integration)
QUICKPAY_API_KEY=
QUICKPAY_PRIVATE_KEY=             # used to validate webhook HMAC signatures

# Resend (find in: resend.com → API keys)
RESEND_API_KEY=
RESEND_FROM_EMAIL=                # e.g. noreply@havnebooking.dk

# App
NEXT_PUBLIC_APP_DOMAIN=           # e.g. havnebooking.dk (no protocol, no trailing slash)
