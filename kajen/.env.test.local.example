# E2e test environment — points at local Supabase, not production.
# 1. Install Docker Desktop and start it
# 2. Run: npx supabase start
# 3. Copy this file: cp .env.test.local.example .env.test.local
# 4. The values below are the well-known defaults for local Supabase —
#    verify them against `npx supabase status` output.
# 5. Run migrations + seed: npx supabase db reset --local
# 6. Run tests: npx playwright test

# Local Supabase (default keys — safe for local dev only, never use in production)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd8rBfr0fryrSNBfBuCTm6dnbCnQCKTs
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SB8o
NEXT_PUBLIC_APP_DOMAIN=

# QuickPay and Resend — not needed for e2e tests (payment flow uses dev bypass)
QUICKPAY_API_KEY=
QUICKPAY_PRIVATE_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# E2e test accounts — global-setup creates these automatically
E2E_ADMIN_EMAIL=e2e-admin@hundested-test.dk
E2E_ADMIN_PASSWORD=e2e-testpass-123
E2E_SUPER_EMAIL=e2e-super@test.dk
E2E_SUPER_PASSWORD=e2e-superpass-123
